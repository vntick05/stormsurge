MODEL_HANDLE=nvidia/Llama-3.1-8B-Instruct-FP4
LLM_PORT=8455
API_PORT=8460
TRTLLM_BASE_URL=http://127.0.0.1:8455
POSTGRES_PORT=5542
POSTGRES_DB=gov_rfp
POSTGRES_USER=gov_rfp
POSTGRES_PASSWORD=replace-with-postgres-password
REDIS_PORT=6479
QDRANT_PORT=6433
MINIO_PORT=9100
MINIO_CONSOLE_PORT=9101
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=replace-with-minio-secret
MINIO_BUCKET_RAW=raw
MINIO_BUCKET_NORMALIZED=normalized
MINIO_BUCKET_PARSED=parsed
MINIO_BUCKET_CHUNKS=chunks
MINIO_BUCKET_OUTPUTS=outputs
MINIO_BUCKET_IMPORTS=imports
TIKA_PORT=10098
TIKA_BASE_URL=http://tika:9998
DOCUMENT_SERVICE_PORT=8181
DOCUMENT_SERVICE_POSTGRES_HOST=postgres
DOCUMENT_SERVICE_POSTGRES_PORT=5432
DOCUMENT_SERVICE_REDIS_URL=redis://redis:6379/0
DOCUMENT_SERVICE_MINIO_ENDPOINT=minio:9000
NORMALIZATION_SERVICE_PORT=8191
NORMALIZATION_PROVIDER=docling
RETRIEVAL_SERVICE_PORT=8481
RETRIEVAL_QDRANT_URL=http://qdrant:6333
RETRIEVAL_QDRANT_COLLECTION=stormsurge_chunks_structured
RETRIEVAL_DOCUMENT_SERVICE_BASE_URL=http://document-service:8181
RETRIEVAL_NORMALIZATION_SERVICE_BASE_URL=http://normalization-service:8191
RETRIEVAL_DEFAULT_DATA_ROOT=/opt/perfect-rfp/data/rfps
RETRIEVAL_EMBEDDING_PROVIDER=fastembed
RETRIEVAL_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
RETRIEVAL_EMBEDDINGS_BASE_URL=
RETRIEVAL_EMBEDDINGS_API_KEY=
RETRIEVAL_CHUNK_SIZE_WORDS=220
RETRIEVAL_CHUNK_OVERLAP_WORDS=40
RETRIEVAL_DEFAULT_TOP_K=5
ANALYSIS_SERVICE_PORT=8192
ANALYSIS_NORMALIZATION_SERVICE_BASE_URL=http://normalization-service:8191
ANALYSIS_RETRIEVAL_SERVICE_BASE_URL=http://retrieval-service:8481
ANALYSIS_LLM_BASE_URL=http://host.docker.internal:8460/v1
ANALYSIS_LLM_MODEL=
ANALYSIS_SUMMARY_TOP_K_PER_QUERY=6
ANALYSIS_SUMMARY_MAX_MATCHES=30
ANALYSIS_SUMMARY_TEMPERATURE=0.2
PROJECTS_ROOT=/opt/perfect-rfp/data/rfps
RETRIEVAL_SERVICE_BASE_URL=http://127.0.0.1:8481
PROJECT_CHAT_TOP_K=8
PROJECT_CHAT_CONTEXT_CHARS=900
OPEN_WEBUI_IMAGE=ghcr.io/open-webui/open-webui:main
OPEN_WEBUI_PORT=3100
WEBUI_URL=http://localhost:3100
ENABLE_OPENAI_API=True
OPENAI_API_BASE_URL=http://host.docker.internal:8460/v1
OPENAI_API_KEY=sk-local-openwebui
ENABLE_OLLAMA_API=False
MAX_BATCH_SIZE=32
FREE_GPU_MEMORY_FRACTION=0.90
TIKTOKEN_ENCODINGS_BASE=/tmp/harmony-reqs
